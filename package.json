{
  "name": "KOA Enterprise Api",
  "version": "1.0.0",
  "main": "app/server.js",
  "scripts": {
    "dev": "cross-env NODE_ENV=local nodemon -r module-alias/register app/server.js",
    "prod": "cross-env NODE_ENV=production node -r module-alias/register app/server.js",
    "db:migrate:local": "cross-env NODE_ENV=local sequelize db:migrate --config app/config/sequelize.config.js",
    "db:migrate:undo:local": "cross-env NODE_ENV=local sequelize db:migrate:undo --config app/config/sequelize.config.js",
    "db:seed:local:all": "cross-env NODE_ENV=local sequelize-cli db:seed:all --config app/config/sequelize.config.js",
    "job:local:run": "cross-env NODE_ENV=local node app/jobs/message.js"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "axios": "^1.5.1",
    "bcrypt": "^6.0.0",
    "custom-env": "^2.0.2",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.0.2",
    "koa": "^2.14.2",
    "koa-body": "^6.0.1",
    "koa-bodyparser": "^4.4.1",
    "koa-combine-routers": "^4.0.2",
    "koa-pino-logger": "^4.0.0",
    "koa-router": "^12.0.0",
    "koa-static": "^5.0.0",
    "module-alias": "^2.2.3",
    "node-cron": "^4.2.1",
    "pino": "^10.3.1",
    "sequelize": "^6.37.7",
    "tedious": "^18.6.1",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "nodemon": "^3.1.9",
    "sequelize-cli": "^6.6.5"
  },
  "_moduleAliases": {
    "@config": "app/config",
    "@connections": "app/connections",
    "@constants": "app/constants",
    "@models": "app/models",
    "@controllers": "app/controllers",
    "@services": "app/services",
    "@middlewares": "app/middlewares",
    "@routes": "app/routes",
    "@utils": "app/utils"
  }
}
